<!DOCTYPE html>
<html lang="kk">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>IT Cyber Evolution</title>

<style>

/* ================= RESET ================= */
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Segoe UI',sans-serif;
scroll-behavior:smooth;
}

body{
background:#0b0f1a;
color:white;
overflow-x:hidden;
}

/* ================= STARS ================= */
.stars{
position:fixed;
width:100%;
height:100%;
background:
radial-gradient(2px 2px at 20% 30%,#00f5ff,transparent),
radial-gradient(2px 2px at 80% 70%,#7a5cff,transparent),
radial-gradient(1px 1px at 40% 60%,white,transparent),
radial-gradient(1px 1px at 90% 20%,#ff4ecd,transparent);
animation:moveStars 120s linear infinite;
z-index:-2;
}

@keyframes moveStars{
from{background-position:0 0;}
to{background-position:2000px 3000px;}
}

/* ================= NAV ================= */
nav{
position:fixed;
top:25px;
left:50%;
transform:translateX(-50%);
background:rgba(255,255,255,0.05);
backdrop-filter:blur(20px);
padding:15px 50px;
border-radius:50px;
display:flex;
gap:35px;
z-index:1000;
border:1px solid rgba(255,255,255,0.15);
}

nav a{
color:white;
text-decoration:none;
font-weight:bold;
transition:0.3s;
}

nav a:hover{
color:#00f5ff;
text-shadow:0 0 15px #00f5ff;
}

/* ================= HEADER ================= */
header{
height:100vh;
display:flex;
flex-direction:column;
justify-content:center;
align-items:center;
text-align:center;
padding:20px;
}

header h1{
font-size:70px;
background:linear-gradient(90deg,#00f5ff,#7a5cff,#ff4ecd);
-webkit-background-clip:text;
-webkit-text-fill-color:transparent;
animation:glow 3s infinite alternate;
}

@keyframes glow{
from{text-shadow:0 0 20px #00f5ff;}
to{text-shadow:0 0 50px #ff4ecd;}
}

header p{
max-width:750px;
margin-top:25px;
opacity:0.85;
}

/* ================= SECTION ================= */
section{
padding:120px 10%;
}

h2{
text-align:center;
font-size:42px;
margin-bottom:60px;
background:linear-gradient(90deg,#00f5ff,#ff4ecd);
-webkit-background-clip:text;
-webkit-text-fill-color:transparent;
}

/* ================= GRID ================= */
.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
gap:40px;
}

/* ================= CARD ================= */
.card{
background:rgba(255,255,255,0.05);
border-radius:25px;
padding:35px;
backdrop-filter:blur(20px);
border:1px solid rgba(255,255,255,0.15);
transition:0.5s;
position:relative;
overflow:hidden;
}

.card::before{
content:"";
position:absolute;
top:0;
left:-100%;
width:100%;
height:100%;
background:linear-gradient(120deg,transparent,rgba(255,255,255,0.2),transparent);
transition:0.6s;
}

.card:hover::before{
left:100%;
}

.card:hover{
transform:translateY(-15px) scale(1.05);
box-shadow:0 0 40px rgba(0,245,255,0.4);
}

/* ================= CIRCULAR PROGRESS ================= */
.circle{
width:150px;
height:150px;
border-radius:50%;
background:conic-gradient(#00f5ff 0% 85%, rgba(255,255,255,0.1) 85%);
display:flex;
align-items:center;
justify-content:center;
margin:auto;
}

.circle span{
font-size:24px;
}

/* ================= ACCORDION ================= */
.accordion input{
display:none;
}

.accordion label{
display:block;
padding:15px;
background:rgba(255,255,255,0.08);
margin-bottom:5px;
cursor:pointer;
border-radius:10px;
}

.accordion-content{
max-height:0;
overflow:hidden;
transition:0.5s;
padding:0 15px;
background:rgba(255,255,255,0.05);
border-radius:0 0 10px 10px;
}

.accordion input:checked + label + .accordion-content{
max-height:200px;
padding:15px;
}

/* ================= FOOTER ================= */
footer{
text-align:center;
padding:50px;
background:rgba(255,255,255,0.05);
backdrop-filter:blur(20px);
}

</style>
</head>

<body>

<div class="stars"></div>

<nav>
<a href="#about">IT</a>
<a href="#skills">Дағдылар</a>
<a href="#future">Болашақ</a>
<a href="#faq">FAQ</a>
</nav>

<header>
